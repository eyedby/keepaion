import { expect } from "chai";
import { ethers } from "hardhat";
import { AMOK, AMOKToken } from "../typechain-types";

// ─────────────────────────────────────────────────────────────
//  AMOK test suite
//  Run: npx hardhat test
// ─────────────────────────────────────────────────────────────

// Mock verifier — always returns true for testing
// Replace with actual Barretenberg verifier in production
const MOCK_VERIFIER_ABI = [
    "function verify(bytes calldata proof, bytes32[] calldata publicInputs) external view returns (bool)"
];

describe("AMOK", () => {
    let amok: AMOK;
    let token: AMOKToken;
    let owner: any, dev1: any, dev2: any;

    // Test commitments and nullifiers (would be ZK-derived in production)
    const commitment1 = ethers.keccak256(ethers.toUtf8Bytes("dev1-commitment"));
    const nullifier1  = ethers.keccak256(ethers.toUtf8Bytes("dev1-nullifier"));
    const commitment2 = ethers.keccak256(ethers.toUtf8Bytes("dev2-commitment"));
    const nullifier2  = ethers.keccak256(ethers.toUtf8Bytes("dev2-nullifier"));
    const initialRoot = ethers.keccak256(ethers.toUtf8Bytes("initial-merkle-root"));
    const mockProof   = ethers.randomBytes(32);

    beforeEach(async () => {
        [owner, dev1, dev2] = await ethers.getSigners();

        // Deploy mock verifier
        const MockVerifier = await ethers.getContractFactory("MockVerifier");
        const verifier = await MockVerifier.deploy();

        // Deploy AMOK
        const AMOKFactory = await ethers.getContractFactory("AMOK");
        amok = await AMOKFactory.deploy(await verifier.getAddress(), initialRoot);

        // Deploy AMOKToken
        const TokenFactory = await ethers.getContractFactory("AMOKToken");
        token = await TokenFactory.deploy(await amok.getAddress());
    });

    describe("registerCommitment", () => {
        it("registers a commitment", async () => {
            await amok.connect(dev1).registerCommitment(commitment1);
            expect(await amok.commitments(commitment1)).to.be.true;
        });

        it("emits CommitmentRegistered", async () => {
            await expect(amok.connect(dev1).registerCommitment(commitment1))
                .to.emit(amok, "CommitmentRegistered")
                .withArgs(commitment1);
        });

        it("reverts on duplicate commitment", async () => {
            await amok.connect(dev1).registerCommitment(commitment1);
            await expect(
                amok.connect(dev1).registerCommitment(commitment1)
            ).to.be.revertedWithCustomError(amok, "AlreadyRegistered");
        });
    });

    describe("pledge", () => {
        beforeEach(async () => {
            await amok.connect(dev1).registerCommitment(commitment1);
        });

        it("accepts valid proof and issues token", async () => {
            const tx = await amok.connect(dev1).pledge(
                mockProof, commitment1, nullifier1, initialRoot
            );
            await expect(tx)
                .to.emit(amok, "PledgeMade")
                .withArgs(1, nullifier1);
            expect(await amok.totalPledges()).to.equal(1);
            expect(await amok.isValid(1)).to.be.true;
        });

        it("increments totalPledges for each unique pledge", async () => {
            await amok.connect(dev1).registerCommitment(commitment1);
            await amok.connect(dev2).registerCommitment(commitment2);
            await amok.connect(dev1).pledge(mockProof, commitment1, nullifier1, initialRoot);
            await amok.connect(dev2).pledge(mockProof, commitment2, nullifier2, initialRoot);
            expect(await amok.totalPledges()).to.equal(2);
        });

        it("reverts on double pledge (same nullifier)", async () => {
            await amok.connect(dev1).pledge(mockProof, commitment1, nullifier1, initialRoot);
            await expect(
                amok.connect(dev1).pledge(mockProof, commitment1, nullifier1, initialRoot)
            ).to.be.revertedWithCustomError(amok, "AlreadyPledged");
        });

        it("reverts on unknown commitment", async () => {
            await expect(
                amok.connect(dev2).pledge(mockProof, commitment2, nullifier2, initialRoot)
            ).to.be.revertedWithCustomError(amok, "CommitmentUnknown");
        });

        it("reverts on invalid root", async () => {
            const wrongRoot = ethers.keccak256(ethers.toUtf8Bytes("wrong-root"));
            await expect(
                amok.connect(dev1).pledge(mockProof, commitment1, nullifier1, wrongRoot)
            ).to.be.revertedWithCustomError(amok, "InvalidRoot");
        });
    });

    describe("updateRoot", () => {
        it("owner can update root", async () => {
            const newRoot = ethers.keccak256(ethers.toUtf8Bytes("new-root"));
            await expect(amok.connect(owner).updateRoot(newRoot))
                .to.emit(amok, "RootUpdated")
                .withArgs(initialRoot, newRoot);
            expect(await amok.pledgeRoot()).to.equal(newRoot);
        });

        it("non-owner cannot update root", async () => {
            const newRoot = ethers.keccak256(ethers.toUtf8Bytes("new-root"));
            await expect(
                amok.connect(dev1).updateRoot(newRoot)
            ).to.be.revertedWithCustomError(amok, "Unauthorized");
        });
    });

    describe("AMOKToken soulbound", () => {
        it("cannot be transferred", async () => {
            await amok.connect(dev1).registerCommitment(commitment1);
            await amok.connect(dev1).pledge(mockProof, commitment1, nullifier1, initialRoot);
            // token.transferFrom should revert
            await expect(
                token.connect(dev1).transferFrom(dev1.address, dev2.address, 1)
            ).to.be.revertedWithCustomError(token, "SoulboundToken");
        });
    });
});
