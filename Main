// AMOK — keepAIon pledge ZK circuit
// Proves: "I signed the keepAIon pledge"
// Conceals: who signed it
//
// eyedby/keepaion · keepAIon.com · v0.1

use dep::std::hash::pedersen_hash;
use dep::std::merkle::compute_merkle_root;

fn main(
    // ── Private inputs (never revealed) ──────────────────────
    secret:              Field,   // hash of developer's passphrase
    github_handle_hash:  Field,   // hash of github.com/username
    path_indices:        [u1; 20],  // merkle proof path indices
    hash_path:           [Field; 20], // merkle proof sibling hashes

    // ── Public inputs (on-chain verifiable) ──────────────────
    commitment:   pub Field,  // hash(secret, github_handle_hash)
    nullifier:    pub Field,  // hash(secret, 0) — prevents double sign
    pledge_root:  pub Field,  // merkle root of all commitments
) {
    // 1. Verify commitment matches private inputs
    //    commitment = pedersen(secret, github_handle_hash)
    let computed_commitment = pedersen_hash([secret, github_handle_hash]);
    assert(
        computed_commitment == commitment,
        "AMOK: commitment mismatch — invalid secret or handle"
    );

    // 2. Verify nullifier is correctly derived from secret
    //    nullifier = pedersen(secret, 0)
    //    Same secret always produces same nullifier — prevents double pledge
    let computed_nullifier = pedersen_hash([secret, 0]);
    assert(
        computed_nullifier == nullifier,
        "AMOK: nullifier mismatch"
    );

    // 3. Verify commitment is in the keepAIon merkle tree
    //    Proves developer registered before generating proof
    let computed_root = compute_merkle_root(commitment, path_indices, hash_path);
    assert(
        computed_root == pledge_root,
        "AMOK: not in pledge tree — register commitment first"
    );
}

// ── Tests ─────────────────────────────────────────────────────
#[test]
fn test_valid_pledge() {
    // Known test vectors
    let secret             = 0x1234567890abcdef1234567890abcdef_Field;
    let github_handle_hash = 0xdeadbeefdeadbeefdeadbeefdeadbeef_Field;

    let commitment = dep::std::hash::pedersen_hash([secret, github_handle_hash]);
    let nullifier  = dep::std::hash::pedersen_hash([secret, 0]);

    // Trivial single-leaf tree for test
    let path_indices: [u1; 20] = [0; 20];
    let hash_path: [Field; 20] = [0; 20];
    let pledge_root = dep::std::merkle::compute_merkle_root(
        commitment, path_indices, hash_path
    );

    main(
        secret, github_handle_hash,
        path_indices, hash_path,
        commitment, nullifier, pledge_root
    );
}

#[test(should_fail)]
fn test_wrong_secret_fails() {
    let secret             = 0x1234567890abcdef1234567890abcdef_Field;
    let wrong_secret       = 0xffffffffffffffffffffffffffffffff_Field;
    let github_handle_hash = 0xdeadbeefdeadbeefdeadbeefdeadbeef_Field;

    let commitment = dep::std::hash::pedersen_hash([secret, github_handle_hash]);
    let nullifier  = dep::std::hash::pedersen_hash([wrong_secret, 0]);

    let path_indices: [u1; 20] = [0; 20];
    let hash_path:   [Field; 20] = [0; 20];
    let pledge_root = dep::std::merkle::compute_merkle_root(
        commitment, path_indices, hash_path
    );

    // Should fail — nullifier derived from wrong secret
    main(
        wrong_secret, github_handle_hash,
        path_indices, hash_path,
        commitment, nullifier, pledge_root
    );
}
