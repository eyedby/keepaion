{
  "name": "amok",
  "version": "0.1.0",
  "description": "AMOK — keepAIon ZKP solidarity system. eyedby/keepaion",
  "scripts": {
    "compile":        "hardhat compile",
    "test":           "hardhat test",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network base-sepolia",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network base",
    "circuit:build":  "cd circuits/amok_pledge && nargo compile",
    "circuit:test":   "cd circuits/amok_pledge && nargo test",
    "circuit:verify": "cd circuits/amok_pledge && nargo codegen-verifier",
    "merkle:root":    "npx ts-node scripts/merkle.ts root",
    "merkle:add":     "npx ts-node scripts/merkle.ts add"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "merkletreejs":            "^0.3.11",
    "ethers":                  "^6.0.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@noir-lang/noir_js":               "^0.30.0",
    "@noir-lang/backend_barretenberg":  "^0.30.0",
    "hardhat":                          "^2.22.0",
    "typescript":                       "^5.0.0",
    "ts-node":                          "^10.0.0",
    "chai":                             "^4.3.0"
  }
}
